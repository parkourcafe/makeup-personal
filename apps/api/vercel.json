{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index.py"
    }
  ],
  "functions": {
    "api/index.py": {
      "maxDuration": 60,
      "excludeFiles": "{app/tests/**,alembic/**,**/__pycache__/**,**/*.pyc,*.db,.venv/**}"
    }
  }
}
