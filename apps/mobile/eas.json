{
  "cli": {
    "version": ">= 20.5.1",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://makeup-personal-api.vercel.app"
      },
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://makeup-personal-api.vercel.app"
      }
    },
    "preview-android": {
      "extends": "preview",
      "android": {
        "buildType": "apk"
      }
    },
    "preview-ios": {
      "extends": "preview",
      "ios": {
        "simulator": true
      }
    },
    "production": {
      "autoIncrement": true,
      "distribution": "store",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://makeup-personal-api.vercel.app"
      },
      "android": {
        "buildType": "app-bundle"
      }
    },
    "production-android": {
      "extends": "production",
      "android": {
        "buildType": "app-bundle"
      }
    },
    "production-ios": {
      "extends": "production"
    }
  },
  "submit": {
    "production": {},
    "production-android": {
      "android": {}
    },
    "production-ios": {
      "ios": {}
    }
  }
}
